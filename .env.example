# Ray Cluster
RAY_HEAD_IP=your_ray_head_ip
RAY_DASHBOARD_URL=http://your_ray_head_ip:8265
RAY_CLIENT_URL=ray://your_ray_head_ip:10001
RAY_HEAD_ADDRESS=your_ray_head_ip:6379

# MinIO
MINIO_ENDPOINT=your_minio_host:9002
MINIO_CONSOLE_URL=http://your_minio_host:19001
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
MINIO_SECURE=false
MINIO_BUCKET=ray-result
 
# Registry
REGISTRY_URL=http://192.168.3.169:15003/
