#!/usr/bin/env bash
set -e

echo ""
echo "  ╔═══════════════════════════════════╗"
echo "  ║   Ray Skills 安装工具             ║"
echo "  ╚═══════════════════════════════════╝"
echo ""

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# ─── 1. 检查 Python ──────────────────────────────────────
echo "[1/6] 检查 Python..."
if ! command -v python3 >/dev/null 2>&1; then
    echo "  ✗ 未找到 python3，请先安装 Python 3.10+"
    exit 1
fi
PY_VER=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
echo "  ✓ Python $PY_VER"

# ─── 2. 安装依赖 ─────────────────────────────────────────
echo ""
echo "[2/6] 安装 Python 依赖..."
if command -v uv >/dev/null 2>&1; then
    uv pip install 'ray[default]' minio 2>/dev/null && echo "  ✓ ray, minio 已安装 (via uv)" || {
        echo "  ✗ 安装失败，请手动运行: uv pip install 'ray[default]' minio"
        exit 1
    }
else
    pip3 install -q 'ray[default]' minio 2>/dev/null && echo "  ✓ ray, minio 已安装 (via pip)" || {
        echo "  ✗ 安装失败，请手动运行: pip install 'ray[default]' minio"
        exit 1
    }
fi

# ─── 3. 配置 .env ────────────────────────────────────────
echo ""
echo "[3/6] 配置集群连接..."

if [ -f "$SCRIPT_DIR/.env" ]; then
    if grep -q "your_access_key\|your_secret_key\|your_api_key\|your_ray_head_ip\|your_minio_host\|FILL_ME\|changeme" "$SCRIPT_DIR/.env" 2>/dev/null; then
        echo "  ⚠ .env 存在但包含占位符，需要更新配置"
        NEED_CONFIG=1
    else
        echo "  ✓ .env 已配置"
        NEED_CONFIG=0
    fi
else
    cp "$SCRIPT_DIR/.env.example" "$SCRIPT_DIR/.env"
    echo "  已从 .env.example 创建 .env"
    NEED_CONFIG=1
fi

if [ "$NEED_CONFIG" = "1" ]; then
    echo ""
    echo "  需要集群地址和 MinIO 密钥。如果不知道，联系集群管理员获取。"
    echo ""
    read -p "  Ray Head 节点 IP（如 192.168.1.100）: " RAY_IP
    read -p "  MinIO 端点（如 192.168.1.100:9002，默认同 Ray IP）: " MINIO_EP
    read -p "  MINIO_ACCESS_KEY: " MINIO_AK
    read -sp "  MINIO_SECRET_KEY: " MINIO_SK
    echo ""

    # 设置默认值
    [ -z "$MINIO_EP" ] && [ -n "$RAY_IP" ] && MINIO_EP="${RAY_IP}:9002"

    if [ -n "$RAY_IP" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^RAY_HEAD_IP=.*|RAY_HEAD_IP=$RAY_IP|" "$SCRIPT_DIR/.env"
            sed -i '' "s|^RAY_DASHBOARD_URL=.*|RAY_DASHBOARD_URL=http://$RAY_IP:8265|" "$SCRIPT_DIR/.env"
            sed -i '' "s|^RAY_CLIENT_URL=.*|RAY_CLIENT_URL=ray://$RAY_IP:10001|" "$SCRIPT_DIR/.env"
            sed -i '' "s|^RAY_HEAD_ADDRESS=.*|RAY_HEAD_ADDRESS=$RAY_IP:6379|" "$SCRIPT_DIR/.env"
            sed -i '' "s|^REGISTRY_URL=.*|REGISTRY_URL=$RAY_IP:5000|" "$SCRIPT_DIR/.env"
        else
            sed -i "s|^RAY_HEAD_IP=.*|RAY_HEAD_IP=$RAY_IP|" "$SCRIPT_DIR/.env"
            sed -i "s|^RAY_DASHBOARD_URL=.*|RAY_DASHBOARD_URL=http://$RAY_IP:8265|" "$SCRIPT_DIR/.env"
            sed -i "s|^RAY_CLIENT_URL=.*|RAY_CLIENT_URL=ray://$RAY_IP:10001|" "$SCRIPT_DIR/.env"
            sed -i "s|^RAY_HEAD_ADDRESS=.*|RAY_HEAD_ADDRESS=$RAY_IP:6379|" "$SCRIPT_DIR/.env"
            sed -i "s|^REGISTRY_URL=.*|REGISTRY_URL=$RAY_IP:5000|" "$SCRIPT_DIR/.env"
        fi
        echo "  ✓ Ray 地址已配置"
    fi

    if [ -n "$MINIO_EP" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^MINIO_ENDPOINT=.*|MINIO_ENDPOINT=$MINIO_EP|" "$SCRIPT_DIR/.env"
        else
            sed -i "s|^MINIO_ENDPOINT=.*|MINIO_ENDPOINT=$MINIO_EP|" "$SCRIPT_DIR/.env"
        fi
    fi

    if [ -n "$MINIO_AK" ] && [ -n "$MINIO_SK" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^MINIO_ACCESS_KEY=.*|MINIO_ACCESS_KEY=$MINIO_AK|" "$SCRIPT_DIR/.env"
            sed -i '' "s|^MINIO_SECRET_KEY=.*|MINIO_SECRET_KEY=$MINIO_SK|" "$SCRIPT_DIR/.env"
        else
            sed -i "s|^MINIO_ACCESS_KEY=.*|MINIO_ACCESS_KEY=$MINIO_AK|" "$SCRIPT_DIR/.env"
            sed -i "s|^MINIO_SECRET_KEY=.*|MINIO_SECRET_KEY=$MINIO_SK|" "$SCRIPT_DIR/.env"
        fi
        echo "  ✓ MinIO 密钥已配置"
    else
        echo "  ⚠ 跳过密钥配置（之后编辑 .env 手动填入）"
    fi
fi

# ─── 4. 安装全局 Skill ───────────────────────────────────
echo ""
echo "[4/6] 安装 Claude Code skills..."
mkdir -p ~/.claude/commands
# 记录安装路径，skill 运行时需要找到 Python 工具
echo "$SCRIPT_DIR" > ~/.claude/.ray-skills-path
for skill in ray-new ray-push ray-status; do
    cp "$SCRIPT_DIR/.claude/commands/${skill}.md" ~/.claude/commands/${skill}.md
    echo "  ✓ /${skill}"
done
echo "  已安装到 ~/.claude/commands/（全局可用）"
echo "  项目路径: $SCRIPT_DIR"

# ─── 5. 安装 git hooks ───────────────────────────────────
echo ""
echo "[5/6] 安装 git hooks..."
if [ -d "$SCRIPT_DIR/.git" ]; then
    cp "$SCRIPT_DIR/hooks/pre-commit" "$SCRIPT_DIR/.git/hooks/pre-commit" 2>/dev/null
    chmod +x "$SCRIPT_DIR/.git/hooks/pre-commit" 2>/dev/null
    echo "  ✓ pre-commit hook（每次提交自动递增版本号）"
else
    echo "  - 跳过（非 git 仓库）"
fi

# ─── 6. 验证环境 ─────────────────────────────────────────
echo ""
echo "[6/6] 验证环境..."
echo ""
python3 "$SCRIPT_DIR/skills/check_env.py" && ENV_OK=1 || ENV_OK=0

# ─── 完成 ────────────────────────────────────────────────
echo ""
if [ "$ENV_OK" = "1" ]; then
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║   安装完成！                       ║"
    echo "  ╚═══════════════════════════════════╝"
else
    echo "  ╔═══════════════════════════════════╗"
    echo "  ║   安装完成（部分检查未通过）        ║"
    echo "  ╚═══════════════════════════════════╝"
    echo ""
    echo "  请根据上面的提示修复问题后重新运行: ./setup"
fi
echo ""
echo "  可用的 skill（任意目录下均可使用）:"
echo "    /ray-new    — 生成 Ray 任务脚本（新手从这里开始）"
echo "    /ray-push   — 验证并提交任务到集群"
echo "    /ray-status — 查看集群和任务状态"
echo ""
echo "  快速开始: 在 Claude Code 里输入 /ray-new"
echo ""
